      "widgets_values": [
        "{\n    \"high_level_description\": \"A high-energy, futuristic racing poster featuring a sleek, neon-drenched retro motorcycle speeding through a rain-slicked cyberpunk alleyway, framed by bold, glitch-effect typography.\",\n    \"style_description\": {\n        \"aesthetics\": \"Cyberpunk noir, high-speed motion blur, glitch art, clean minimalist streetwear design with intense neon accents.\",\n        \"lighting\": \"Deep, moody shadows contrasted with vibrant cyan and magenta neon light reflections on wet pavement.\",\n        \"photo\": \"Sharp 8k digital capture with subtle chromatic aberration and anamorphic lens flares.\",\n        \"medium\": \"Digital illustration with vector-style precision.\",\n        \"color_palette\": [\"#00F5FF\", \"#FF007F\", \"#121212\", \"#4A4A4A\", \"#FFFFFF\"]\n    },\n    \"compositional_deconstruction\": {\n        \"background\": \"A narrow, towering cyberpunk alleyway at night. Wet asphalt surfaces reflect overhead neon signage in a painterly, blurred motion streak.\",\n        \"elements\": [\n            {\n                \"type\": \"obj\",\n                \"bbox\": [100, 200, 900, 500],\n                \"desc\": \"A sharp, side-profile view of a futuristic cafe-racer motorcycle. The body is matte black with pulsing cyan LED trim glowing from the frame.\",\n                \"color_palette\": [\"#00F5FF\", \"#121212\", \"#4A4A4A\"]\n            },\n            {\n                \"type\": \"obj\",\n                \"bbox\": [200, 50, 800, 150],\n                \"desc\": \"Bold, aggressive typographic layout spelling 'IG4 Solo' at the top, suffering from a horizontal chromatic shift/glitch effect.\",\n                \"color_palette\": [\"#FF007F\", \"#FFFFFF\"]\n            },\n            {\n                \"type\": \"obj\",\n                \"bbox\": [50, 700, 950, 900],\n                \"desc\": \"A heavy, distorted industrial metal plate texture at the bottom, partially obscured by a bright magenta neon spray-paint 'X' mark.\",\n                \"color_palette\": [\"#FF007F\", \"#4A4A4A\"]\n            }\n        ]\n    }\n}"
      ]
